{
    "name": "alxarafe/workframe",
    "description": "WorkFrame Application",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.2",
        "alxarafe/alxarafe": "v0.4.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "phpstan/phpstan": "^2.1",
        "php-debugbar/php-debugbar": "^3.3",
        "vimeo/psalm": "^6.15",
        "phpmd/phpmd": "^2.15",
        "phpmetrics/phpmetrics": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "Modules\\": "Modules/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php scripts/publish_theme_assets.php"
        ],
        "post-update-cmd": [
            "php scripts/publish_theme_assets.php"
        ]
    }
}